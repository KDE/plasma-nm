#: openconnectwebauthdialog.cpp:140
#, kde-format
msgid "Use your security key with %1"
msgstr "%1 ئارقىلىق بىخەتەرلىك ئاچقۇچىڭىزنى ئىشلىتىڭ"

#: openconnectwebauthdialog.cpp:141
#, kde-format
msgid "Touch your security key again to complete the request."
msgstr "ئىلتىماسنى تاماملاش ئۈچۈن بىخەتەرلىك ئاچقۇچىڭىزنى قايتا چېكىڭ."

