#: openconnectwebauthdialog.cpp:191
#, kde-format
msgid "Wrong PIN. %1 attempt remaining."
msgid_plural "Wrong PIN. %1 attempts remaining."
msgstr[0] "PIN خاتا. يەنە %1 قېتىم سىناش پۇرسىتى قالدى."

#: openconnectwebauthdialog.cpp:194
#, kde-format
msgid "Too Short. %1 attempt remaining."
msgid_plural "Too Short. %1 attempts remaining."
msgstr[0] "بەك قىسقا. يەنە %1 قېتىم سىناش پۇرسىتى قالدى."

#: openconnectwebauthdialog.cpp:197
#, kde-format
msgid "Invalid Characters. %1 attempt remaining."
msgid_plural "Invalid Characters. %1 attempts remaining."
msgstr[0] "ئىناۋەتسىز ھەرپ. يەنە %1 قېتىم سىناش پۇرسىتى قالدى."

#: openconnectwebauthdialog.cpp:201
#, kde-format
msgid "Same as current PIN. %1 attempt remaining."
msgid_plural "Same as current PIN. %1 attempts remaining."
msgstr[0] "نۆۋەتتىكى PIN بىلەن ئوخشاش. يەنە %1 قېتىم سىناش پۇرسىتى قالدى."

#: openconnectwebauthdialog.cpp:239
#, kde-format
msgid "Something went wrong"
msgstr "كاشىلا كۆرۈلدى"

#: openconnectwebauthdialog.cpp:243
#, kde-format
msgid "Request Timeout"
msgstr "ئىلتىماس ۋاقتى ئۆتتى"

#: openconnectwebauthdialog.cpp:246
#, kde-format
msgid "Key not registered"
msgstr "ئاچقۇچ تىزىملىتىلمىغان"

#: openconnectwebauthdialog.cpp:250
#, kde-format
msgid "You already registered this device.Try again with device"
