#: openconnectwebauthdialog.cpp:256
#, kde-format
msgid ""
"The security key is locked because the wrong PIN was entered too many times."
"To unlock it, remove and reinsert it."
msgstr ""
"بىخەتەرلىك ئاچقۇچى قۇلۇپلاندى چۈنكى خاتا PIN كۆپ قېتىم كىرگۈزۈلگەن. قۇلۇپ "
"ئېچىشتا، شىفىرلىق ئاچقۇچنى چىقىرىۋېتىپ قايتا قىستۇرۇش كېرەك."

#: openconnectwebauthdialog.cpp:262
#, kde-format
msgid ""
"The security key is locked because the wrong PIN was entered too many times. "
"You'll need to reset the security key."
msgstr ""
"بىخەتەرلىك ئاچقۇچى قۇلۇپلاندى چۈنكى خاتا PIN كۆپ قېتىم كىرگۈزۈلگەن. "
"بىخەتەرلىك ئاچقۇچىنى ئەسلىگە قايتۇرۇشىڭىز كېرەك."

#: openconnectwebauthdialog.cpp:266
#, kde-format
msgid ""
"Authenticator removed during verification. Please reinsert and try again"
msgstr ""
"كىملىك دەلىللىگۈچ دەلىللەش جەريانىدا چىقىرىۋەتتى. قايتا قىستۇرۇپ ئاندىن "
"قايتا سىناڭ"

#: openconnectwebauthdialog.cpp:269
#, kde-format
msgid "Authenticator doesn't have resident key support"
msgstr "كىملىك دەلىللىگۈچ دائىملىق ئاچقۇچنى قوللىمايدۇ"

#: openconnectwebauthdialog.cpp:272
#, kde-format
msgid "Authenticator missing user verification"
msgstr "كىملىك دەلىللىگۈچتە ئىشلەتكۈچى كىملىك دەلىللىشى كەم"

#: openconnectwebauthdialog.cpp:275
#, kde-format
msgid "Authenticator missing Large Blob support"
msgstr "كىملىك دەلىللىگۈچتە چوڭ سانلىق مەلۇمات بۆلىكىنى قوللاش كەم"

#: openconnectwebauthdialog.cpp:278
#, kde-format
msgid ""
"The security token does not support the server’s required authentication "
"method."
msgstr ""
"بىخەتەرلىك پەرمان تاختىسى مۇلازىمېتىرغا زۆرۈر كىملىك دەلىللەش ئۇسۇلىنى "
"قوللىمايدۇ."

